<!DOCTYPE html>
<html lang="en">
<head>
<title>Explore Ooty</title>
<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: Arial, sans-serif;
}
body{
    background:url('ooty-bg.jpg') no-repeat center center/cover;
    height:100vh;
    color:white;
}
.overlay{
    background:rgba(0,0,0,0.5);
    height:100vh;
}
header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:20px 50px;
}
.logo{
    font-size:30px;
    font-weight:bold;
    color:#90ee90;
}
nav a{
    text-decoration:none;
    color:white;
    margin-left:20px;
    font-size:18px;
}
.hero{
    text-align:center;
    margin-top:150px;
}
.hero h1{
    font-size:60px;
    margin-bottom:15px;
}
.hero p{
    font-size:22px;
    margin-bottom:25px;
}
.btn{
    text-decoration:none;
    background:#28a745;
    color:white;
    padding:12px 25px;
    border-radius:30px;
    font-size:18px;
    transition:0.3s;
}
.btn:hover{
    background:#1e7e34;
}
.places{
    display:flex;
    justify-content:center;
    gap:25px;
    margin-top:80px;
    flex-wrap:wrap;
}
.card{
    width:250px;
    background:rgba(255,255,255,0.15);
    backdrop-filter:blur(5px);
    padding:20px;
    border-radius:15px;
    text-align:center;
}
.card h3{
    margin-bottom:10px;
    color:#90ee90;
}
.card p{
    font-size:15px;
}
</style>
</head>
<body>
<div class="overlay">

<header>
    <div class="logo">Explore Ooty</div>
    <nav>
        <a href="#">Home</a>
        <a href="#">Places</a>
        <a href="#">Gallery</a>
        <a href="#">Contact</a>
    </nav>
</header>

<section class="hero">
    <h1>Welcome to Ooty</h1>
    <p>The Queen of Hill Stations</p>
    <a href="#" class="btn">Plan Your Trip</a>
</section>

<section class="places">
    <div class="card">
        <h3>Ooty Lake</h3>
        <p>Enjoy boating and scenic views surrounded by lush greenery.</p>
    </div>

    <div class="card">
        <h3>Doddabetta Peak</h3>
        <p>The highest peak in the Nilgiris offering breathtaking views.</p>
    </div>

    <div class="card">
        <h3>Botanical Garden</h3>
        <p>Explore exotic plants, flowers, and beautiful landscapes.</p>
    </div>
</section>
</div>
</body>
</html>

