<!DOCTYPE html>
<html lang="en">
<head>
<title>Spotify Dashboard</title>

<style>
{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: Arial, sans-serif;
}

body{
    background:#121212;
    color:white;
    height:100vh;
    display:flex;
}

.sidebar{
    width:250px;
    background:#000;
    padding:20px;
    display:flex;
    flex-direction:column;
}
.menu{
    list-style:none;
}
.menu li:hover{
    color:white;
}

.playlists{
    margin-top:30px;
    border-top:1px solid #282828;
    padding-top:20px;
}

.playlists h4{
    margin-bottom:15px;
    color:#b3b3b3;
}

.main{
    flex:1;
    display:flex;
    flex-direction:column;
}
 search{
    width:300px;
    padding:10px 15px;
    border:none;
    border-radius:20px;
}

 profile{
    background:#282828;
    padding:10px 20px;
    border-radius:20px;
}

 content{
    flex:1;
    padding:30px;
    overflow:auto;
}

 content h2{
    margin-bottom:20px;
}
 cards{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(180px,1fr));
    gap:20px;
}
 card:hover{
    background:#282828;
}

 card img{
    width:100%;
    border-radius:8px;
}

.card h4{
    margin-top:12px;
}

.card p{
    color:#b3b3b3;
    font-size:14px;
    margin-top:8px;
}
.player{
    height:90px;
    background:#181818;
    border-top:1px solid #282828;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:0 20px;
}

.song-info{
    display:flex;
    align-items:center;
    gap:15px;
}

.song-info img{
    width:60px;
    height:60px;
    border-radius:5px;
}

.controls{
    font-size:24px;
    display:flex;
    gap:20px;
}

.controls button{
    background:none;
    border:none;
    color:white;
    cursor:pointer;
    font-size:22px;
}

.volume{
    width:150px;
}
</style>
</head>
<body>
<div class="sidebar">
    <div class="logo">Spotify</div>
    <ul class="menu">
        <li>Home</li>
        <li>Search</li>
        <li>Your Library</li>
    </ul>

    <div class="playlists">
        <h4>Playlists</h4>
        <p>Liked Songs</p>
        <p>Top Hits 2025</p>
        <p>Workout Mix</p>
        <p>Chill Vibes</p>
    </div>
</div>
<div class="main">
    <div class="topbar">
        <input type="text" class="search" placeholder="Search music...">
        <div class="profile">User</div>
    </div>

    <div class="content">
        <h2>Good Evening</h2>
        <div class="cards">
            <div class="card">
                <img src="https://picsum.photos/300?1" alt="">
                <h4>Today's Top Hits</h4>
                <p>The hottest tracks right now.</p>
            </div>

            <div class="card">
                <img src="https://picsum.photos/300?2" alt="">
                <h4>Chill Mix</h4>
                <p>Relax and unwind.</p>
            </div>

            <div class="card">
                <img src="https://picsum.photos/300?3" alt="">
                <h4>Workout</h4>
                <p>Boost your energy.</p>
            </div>

            <div class="card">
                <img src="https://picsum.photos/300?4" alt="">
                <h4>Focus</h4>
                <p>Deep concentration music.</p>
            </div>

            <div class="card">
                <img src="https://picsum.photos/300?5" alt="">
                <h4>Rock Classics</h4>
                <p>Legendary rock songs.</p>
            </div>
        </div>
    </div>

    <div class="player">
        <div class="song-info">
            <img src="https://picsum.photos/100" alt="">
            <div>
                <h4>Blinding Lights</h4>
                <p>The Weeknd</p>
            </div>
        </div>

        <div class="controls">
            <button>⏮</button>
            <button>▶</button>
            <button>⏭</button>
        </div>
        <input type="range" class="volume">
    </div>
</div>
</body>
</html>
