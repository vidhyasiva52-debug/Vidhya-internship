<!DOCTYPE html>
<html lang="en">
<head>
<title>Amazon Store</title>

<style>

body{
    background:white;
}
header{
    background:#131921;
    color:white;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:15px 30px;
}

.search-bar{
    flex:1;
    display:flex;
    margin:0 30px;
}

.search-bar button{
    padding:10px 15px;
    background:#febd69;
    border:none;
    cursor:pointer;
}
.hero{
    height:350px;
    background:
    linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)),
    url('https://images.unsplash.com/photo-1523275335684-37898b6baf30?auto=format&fit=crop&w=1500&q=80');
    background-size:cover;
    background-position:center;
    display:flex;
    justify-content:center;
    align-items:center;
    color:white;
    text-align:center;
}



.products h2{
    margin-bottom:20px;
}

.product-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.card img{
    width:100%;
    height:220px;
    object-fit:cover;
    border-radius:8px;
}

.price{
    color:green;
    font-size:20px;
    font-weight:bold;
    margin-bottom:10px;
}


.btn:hover{
    background:#e68a00;
}

footer{
    background:#131921;
    color:white;
    text-align:center;
    padding:20px;
    margin-top:30px;
}
</style>
</head>
<body>

<header>
    <div class="logo">Amazon</div>

    <div class="search-bar">
        <input type="text" placeholder="Search products...">
        <button>🔍</button>
    </div>

    <div class="nav-links">
        <a href="#">Account</a>
        <a href="#">Orders</a>
        <a href="#">Cart</a>
    </div>
</header>

<section class="hero">
    
</section>

<section class="products">
    <h2>Featured Products</h2>

    <div class="product-grid">

        <div class="card">
            <img src="https://picsum.photos/300/220?random=1" alt="">
            <h3>Wireless Headphones</h3>
            <div class="price">₹1,999</div>
            <button class="btn">Add to Cart</button>
        </div>

        <div class="card">
            <img src="https://picsum.photos/300/220?random=2" alt="">
            <h3>Smart Watch</h3>
            <div class="price">₹2,499</div>
            <button class="btn">Add to Cart</button>
        </div>

        <div class="card">
            <img src="https://picsum.photos/300/220?random=3" alt="">
            <h3>Bluetooth Speaker</h3>
            <div class="price">₹1,299</div>
            <button class="btn">Add to Cart</button>
        </div>

        <div class="card">
            <img src="https://picsum.photos/300/220?random=4" alt="">
            <h3>Gaming Mouse</h3>
            <div class="price">₹899</div>
            <button class="btn">Add to Cart</button>
        </div>

    </div>
</section>
</body>
</html>

