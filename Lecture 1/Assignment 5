<!DOCTYPE html>
<html>
<head>
    <title>Application Form</title>
    <style>
        h1 {
            text-align: center;
            color: #003366;
        }
        label {
            font-weight: bold;
            display: block;
            margin-top: 10px;
        }
        input, select, textarea {
            width: 100%;
            padding: 8px;
            margin-top: 5px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }
        .gender {
            width: auto;
        }
    </style>
</head>
<body>
<div class="container">
    <h1>Application Form</h1>
    <form>
        <label>Full Name</label>
        <input type="text" placeholder="Enter your full name" required>
        <label>Date of Birth</label>
        <input type="date" required>
        <label>Gender</label>
        <input type="radio" name="gender" class="gender"> Male
        <input type="radio" name="gender" class="gender"> Female
        <input type="radio" name="gender" class="gender"> Other
        <label>Email Address</label>
        <input type="email" placeholder="Enter your email" required>
        <label>Phone Number</label>
        <input type="tel" placeholder="Enter your phone number" required>
        <label>Address</label>
        <textarea rows="4" placeholder="Enter your address"></textarea>
        <label>Course Applying For</label>
        <select required>
            <option value="">-- Select Course --</option>
            <option>B.Sc Computer Science</option>
            <option>BCA</option>
            <option>B.Com</option>            
        </select>
        <label>12th Grade Percentage</label>
        <input type="number" min="0" max="100" placeholder="Enter percentage" required>
        <label>Upload Marksheet</label>
        <input type="file">
        <button type="submit" class="btn">Submit Application</button>
    </form>
</div>
</body>
</html>
