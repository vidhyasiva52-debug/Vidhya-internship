<!DOCTYPE html>
<html>
<head>
    <title>Student Report Card</title>
    <style>
        body {            
            background-color: #f5f5f5;            
        }
        report-card {
            width: 600px;
            margin: auto;
            background: white;
            border: 2px solid #333;
            padding: 20px;
            border-radius: 10px;
        }
        student-info {
            margin-bottom: 20px;
        }

        student-info p {
            font-size: 18px;
            margin: 5px 0;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        table, th, td {
            border: 1px solid #333;
        }
        th {
            background-color: #004080;
            color: white;
            padding: 10px;
        }
        td {
            text-align: center;
            padding: 10px;
        }

        summary {
            margin-top: 20px;
            font-size: 18px;
        }

        grade {
            font-weight: bold;
            color: green;
        }
    </style>
</head>
<body>

<div class="report-card">
    <h1>Student Report Card</h1>

    <div class="student-info">
        <p><strong>Name:</strong> Vidhya</p>
        <p><strong>Roll No:</strong> 2422J0893</p>
        <p><strong>Class:</strong> BCA</p>
    </div>

    <table>
        <tr>
            <th>Subject</th>
            <th>Marks Obtained</th>
            <th>Maximum Marks</th>
        </tr>
        <tr>
            <td>System Software</td>
            <td>92</td>
            <td>100</td>
        </tr>
        <tr>
            <td>Business Accounts</td>
            <td>88</td>
            <td>100</td>
        </tr>
        <tr>
            <td>Linuk</td>
            <td>85</td>
            <td>100</td>
        </tr>
        <tr>
            <td>Web Programming Lab</td>
            <td>90</td>
            <td>100</td>
        </tr>
        <tr>
            <td>General Awarness</td>
            <td>95</td>
            <td>100</td>
        </tr>
    </table>

    <div class="summary">
        <p><strong>Total Marks:</strong> 450 / 500</p>
        <p><strong>Percentage:</strong> 90%</p>
        
    </div>
</div>
</body>
</html>
</html>

