    }
    .resume {
        max-width: 900px;
        margin: auto;
        background: white;
        display: flex;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        border-radius: 10px;
        overflow: hidden;
    }
    .left {
        width: 35%;
        background: #2c3e50;
        color: white;
        padding: 25px;
    }
    .name {
        text-align: center;
        margin-top: 15px;
    }
    .section {
        margin-top: 25px;
    }

    .right {
        width: 65%;
        padding: 30px;
    }

    .right h2 {
        color: #2c3e50;
        margin-bottom: 10px;
    }

    .right p {
        margin-bottom: 15px;
        line-height: 1.7;
    }

    .job {
        margin-bottom: 20px;
    }

    .job h4 {
        color: #34495e;
    }

    audio {
        width: 100%;
        margin-top: 10px;
    }
</style>
</head>

<body>

<div class="resume">
