        <img src="profile.jpg" alt="Profile Photo" class="profile-img">

        <h2 class="name">Vidhya</h2>      
        <div class="section">
            <h3>Contact</h3>
            <p>vidhyasiva52@gmail.com</p>
            <p>7449070936</p>
        </div>

        <div class="section">
            <h3>Skills</h3>
            <ul>
                <li>HTML</li>
                <li>Java</li>
                <li>Python</li>                
            </ul>
        </div>

        <div class="section">
            <h3>Audio Introduction</h3>
            <audio controls>
                <source src="intro.mp3" type="audio/mpeg">
                Your browser does not support audio.
